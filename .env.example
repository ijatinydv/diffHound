# GitHub App credentials
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=        # paste the contents of your .pem file here (keep newlines as \n)
GITHUB_WEBHOOK_SECRET=     # the random string you set in GitHub App settings
GITHUB_CLIENT_ID=          # from GitHub App settings page
GITHUB_CLIENT_SECRET=      # from GitHub App settings page

# Redis (for BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Database (PostgreSQL + pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diffhound

# LLM Keys (BYOK — user brings their own)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# App
PORT=3000
NODE_ENV=development